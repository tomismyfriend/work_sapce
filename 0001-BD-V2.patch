Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

---
 drv/hisi_comp.c | 100 ++++++++++++++++++++++++++++++++++++++++--------
 1 file changed, 84 insertions(+), 16 deletions(-)

diff --git a/drv/hisi_comp.c b/drv/hisi_comp.c
index 97bcf39..3767ecd 100644
--- a/drv/hisi_comp.c
+++ b/drv/hisi_comp.c
@@ -60,6 +60,22 @@
 #define HZ_CTX_ST_MASK			0x000f
 #define HZ_CTX_BFINAL_MASK		0x80
 #define HZ_CTX_STORE_MASK		0x7ffff
+
+#define HZ_V5_CTX_BFINAL_MASK		0x03
+#define HZ_V5_CTX_BTYPE_MASK		0x0c
+#define HZ_V5_CTX_BFINAL_END		0x01
+#define HZ_V5_CTX_BFINAL_CONTINUE	0x02
+#define HZ_V5_CTX_STATUS_MASK		0xffff
+#define HZ_V5_CTX_INFO_CHECK_MASK	0xffff0000
+#define HZ_V5_CTX_STATUS_DECOMP_DONE	0x0001
+#define HZ_V5_CTX_STATUS_BTYPE_ERR	0x0002
+#define HZ_V5_CTX_STATUS_STORE_HEAD_ERR	0x0004
+#define HZ_V5_CTX_STATUS_STORE_DECOMP_ERR	0x0008
+#define HZ_V5_CTX_STATUS_STATIC_ERR	0x0010
+#define HZ_V5_CTX_STATUS_DYNAMIC_ERR	0x0020
+#define HZ_V5_CTX_STATUS_DYNAMIC_TBL_ERR	0x0040
+#define HZ_V5_CTX_STATUS_CRC_ALIGN_ERR	0x0080
+#define HZ_V5_CTX_STATUS_CRC_DATA_ERR	0x0100
 #define HZ_LSTBLK_MASK			0x0100
 #define HZ_STATUS_MASK			0xff
 #define HZ_REQ_TYPE_MASK		0xff
@@ -627,10 +643,11 @@ static int fill_buf_addr(struct hisi_zip_sqe *sqe, struct hisi_comp_sqe_addr *ad
 	return 0;
 }
 
-static int fill_buf_deflate_generic(struct hisi_zip_sqe *sqe,
+static int fill_buf_deflate_generic(handle_t h_qp, struct hisi_zip_sqe *sqe,
 				    struct wd_comp_msg *msg,
 				    const char *head, int head_size)
 {
+	struct hisi_qp *qp = (struct hisi_qp *)h_qp;
 	struct hisi_comp_sqe_addr addr = {0};
 	__u32 in_size = msg->req.src_len;
 	__u32 out_size = msg->avail_out;
@@ -641,10 +658,16 @@ static int fill_buf_deflate_generic(struct hisi_zip_sqe *sqe,
 	int ret;
 
 	/*
+	 * v5 stream decompress mode does not support internal store buffer.
 	 * When the output buffer is smaller than the SW_STOREBUF_TH in STATEFUL,
 	 * the internal buffer is used. It requires a storage buffer when returning 1.
 	 */
-	ret = check_enable_store_buf(msg, out_size, head_size);
+	if (qp->q_info.hw_type >= HISI_QM_API_VER5_BASE &&
+	    msg->stream_mode == WD_COMP_STATEFUL &&
+	    msg->req.op_type == WD_DIR_DECOMPRESS)
+		ret = 0;
+	else
+		ret = check_enable_store_buf(msg, out_size, head_size);
 	if (ret) {
 		if (!msg->ctx_buf) {
 			WD_ERR("ctx_buf is NULL when out_size is less than 200!\n");
@@ -696,19 +719,19 @@ static int fill_buf_deflate_generic(struct hisi_zip_sqe *sqe,
 static int fill_buf_deflate(handle_t h_qp, struct hisi_zip_sqe *sqe,
 			    struct wd_comp_msg *msg)
 {
-	return fill_buf_deflate_generic(sqe, msg, NULL, 0);
+	return fill_buf_deflate_generic(h_qp, sqe, msg, NULL, 0);
 }
 
 static int fill_buf_zlib(handle_t h_qp, struct hisi_zip_sqe *sqe,
 			 struct wd_comp_msg *msg)
 {
-	return fill_buf_deflate_generic(sqe, msg, ZLIB_HEADER, ZLIB_HEADER_SZ);
+	return fill_buf_deflate_generic(h_qp, sqe, msg, ZLIB_HEADER, ZLIB_HEADER_SZ);
 }
 
 static int fill_buf_gzip(handle_t h_qp, struct hisi_zip_sqe *sqe,
 			 struct wd_comp_msg *msg)
 {
-	return fill_buf_deflate_generic(sqe, msg, GZIP_HEADER, GZIP_HEADER_SZ);
+	return fill_buf_deflate_generic(h_qp, sqe, msg, GZIP_HEADER, GZIP_HEADER_SZ);
 }
 
 static int check_lz4_msg(struct wd_comp_msg *msg, enum wd_buff_type buf_type)
@@ -809,6 +832,7 @@ static int fill_buf_deflate_sgl_generic(handle_t h_qp, struct hisi_zip_sqe *sqe,
 					struct wd_comp_msg *msg, const char *head,
 					int head_size)
 {
+	struct hisi_qp *qp = (struct hisi_qp *)h_qp;
 	struct wd_comp_req *req = &msg->req;
 	struct wd_datalist *list_dst = req->list_dst;
 	__u32 out_size = msg->avail_out;
@@ -819,10 +843,16 @@ static int fill_buf_deflate_sgl_generic(handle_t h_qp, struct hisi_zip_sqe *sqe,
 	int ret;
 
 	/*
+	 * v5 stream decompress mode does not support internal store buffer.
 	 * When the output buffer is smaller than the SW_STOREBUF_TH in STATEFUL,
 	 * the internal buffer is used. It requires a storage buffer when returning 1.
 	 */
-	ret = check_enable_store_buf(msg, out_size, head_size);
+	if (qp->q_info.hw_type >= HISI_QM_API_VER5_BASE &&
+	    msg->stream_mode == WD_COMP_STATEFUL &&
+	    msg->req.op_type == WD_DIR_DECOMPRESS)
+		ret = 0;
+	else
+		ret = check_enable_store_buf(msg, out_size, head_size);
 	if (ret) {
 		if (!msg->ctx_buf) {
 			WD_ERR("ctx_buf is NULL when out_size is less than 200!\n");
@@ -1581,14 +1611,25 @@ static int fill_zip_comp_sqe(struct hisi_qp *qp, struct wd_comp_msg *msg,
 		    (state << STREAM_MODE_SHIFT) |
 		    (flush_type)) << STREAM_FLUSH_SHIFT;
 	sqe->dw9 |= win_sz << WINDOW_SIZE_SHIFT;
-	sqe->isize = msg->isize;
-	sqe->dw31 = msg->checksum;
-
-	if (msg->ctx_buf) {
-		sqe->ctx_dw0 = *(__u32 *)msg->ctx_buf;
-		sqe->ctx_dw1 = *(__u32 *)(msg->ctx_buf + CTX_DW1_OFFSET);
-		sqe->ctx_dw2 = *(__u32 *)(msg->ctx_buf + CTX_DW2_OFFSET);
+	if (hw_type >= HISI_QM_API_VER5_BASE &&
+	    msg->stream_mode == WD_COMP_STATEFUL &&
+	    msg->req.op_type == WD_DIR_DECOMPRESS) {
+		if (msg->ctx_buf)
+			sqe->ctx_dw0 = *(__u32 *)msg->ctx_buf;
+		else
+			sqe->ctx_dw0 = 0;
+		sqe->ctx_dw1 = 0;
+		sqe->ctx_dw2 = 0;
+		sqe->isize = 0;
+	} else {
+		sqe->isize = msg->isize;
+		if (msg->ctx_buf) {
+			sqe->ctx_dw0 = *(__u32 *)msg->ctx_buf;
+			sqe->ctx_dw1 = *(__u32 *)(msg->ctx_buf + CTX_DW1_OFFSET);
+			sqe->ctx_dw2 = *(__u32 *)(msg->ctx_buf + CTX_DW2_OFFSET);
+		}
 	}
+	sqe->dw31 = msg->checksum;
 
 	return 0;
 }
@@ -1682,6 +1723,7 @@ static void get_ctx_buf(struct hisi_zip_sqe *sqe,
 static int parse_zip_sqe(struct hisi_qp *qp, struct hisi_zip_sqe *sqe,
 			 struct wd_comp_msg *msg)
 {
+	enum hisi_hw_type hw_type = qp->q_info.hw_type;
 	__u32 buf_type = (sqe->dw9 & HZ_BUF_TYPE_MASK) >> BUF_TYPE_SHIFT;
 	__u32 ctx_win_len = sqe->ctx_dw2 & CTX_WIN_LEN_MASK;
 	__u16 ctx_st = sqe->ctx_dw0 & HZ_CTX_ST_MASK;
@@ -1689,8 +1731,9 @@ static int parse_zip_sqe(struct hisi_qp *qp, struct hisi_zip_sqe *sqe,
 	__u32 status = sqe->dw3 & HZ_STATUS_MASK;
 	__u32 type = sqe->dw9 & HZ_REQ_TYPE_MASK;
 	struct wd_comp_msg *recv_msg = msg;
+	bool v5_stream_decomp = false;
 	bool need_debug = wd_need_debug();
-	__u32 bit_cnt, tag;
+	__u32 ctx_status, bit_cnt, tag;
 	int alg_type, ret;
 	void *cache_data;
 
@@ -1731,6 +1774,26 @@ static int parse_zip_sqe(struct hisi_qp *qp, struct hisi_zip_sqe *sqe,
 
 	ops[alg_type].get_data_size(sqe, qp->q_info.qc_type, recv_msg);
 
+	v5_stream_decomp = (hw_type >= HISI_QM_API_VER5_BASE &&
+			    recv_msg->stream_mode == WD_COMP_STATEFUL &&
+			    recv_msg->req.op_type == WD_DIR_DECOMPRESS);
+
+	if (v5_stream_decomp) {
+		ctx_status = sqe->isize & HZ_V5_CTX_STATUS_MASK;
+		if (ctx_status & HZ_V5_CTX_STATUS_DECOMP_DONE) {
+			recv_msg->req.status = WD_STREAM_END;
+		} else if (ctx_status && sqe->consumed == 0 && sqe->produced == 0) {
+			WD_ERR("v5 stream decomp error: ctx_status=0x%x!\n", ctx_status);
+			recv_msg->req.status = WD_EAGAIN;
+		} else if (ctx_status) {
+			WD_ERR("v5 stream decomp error: ctx_status=0x%x!\n", ctx_status);
+			recv_msg->req.status = WD_IN_EPARA;
+		}
+		if (recv_msg->ctx_buf)
+			*(__u32 *)recv_msg->ctx_buf = sqe->ctx_dw0;
+		goto skip_cache_process;
+	}
+
 	get_ctx_buf(sqe, recv_msg);
 
 	/* last block no space, need resend null size req */
@@ -1763,14 +1826,19 @@ static int parse_zip_sqe(struct hisi_qp *qp, struct hisi_zip_sqe *sqe,
 		}
 	}
 
+skip_cache_process:
 	if (need_debug)
 		WD_DEBUG("zip recv lst =%hu, ctx_st=0x%x, status=0x%x, alg=%u!\n",
 		 lstblk, ctx_st, status, type);
 	if (lstblk && (status == HZ_DECOMP_END))
 		recv_msg->req.status = WD_STREAM_END;
 
-	recv_msg->isize = sqe->isize;
-	recv_msg->checksum = sqe->dw31;
+	if (!v5_stream_decomp) {
+		recv_msg->isize = sqe->isize;
+		recv_msg->checksum = sqe->dw31;
+	} else {
+		recv_msg->checksum = sqe->dw31;
+	}
 	recv_msg->alg_type = alg_type;
 
 	if (recv_msg->mm_ops && !recv_msg->mm_ops->sva_mode)
-- 
2.47.0.windows.2

